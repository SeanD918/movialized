{
  "version": 2,
  "outputDirectory": "client/dist",
  "functions": {
    "api/**/*.js": {
      "includeFiles": "server/data.json"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
